generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  isAdmin         Boolean  @default(false)
  emailVerified   Boolean  @default(false)
  verifyToken     String?
  plan            String   @default("free")
  createdAt       DateTime @default(now())
  profiles        Profile[]
}

model Profile {
  id          String   @id @default(cuid())
  slug        String   @unique
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isDefault   Boolean  @default(true)
  cardName    String   @default("My Card")

  fullName    String
  jobTitle    String?
  company     String?
  bio         String?
  photoUrl    String?

  phone       String?
  email       String?
  website     String?

  linkedin    String?
  instagram   String?
  twitter     String?
  whatsapp    String?

  theme       String   @default("dark")
  isPublic    Boolean  @default(true)
  sectionOrder String  @default("contact,social,links")

  customLinks CustomLink[]
  taps        Tap[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CustomLink {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label     String
  url       String
  icon      String  @default("link")
  order     Int     @default(0)
}

model Tap {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  device    String?
  createdAt DateTime @default(now())
}
